CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
PUBLIC_SITE_URL=https://UIshades.com

# --- Auth (login + presets) ---
# These are Worker SECRETS, not build-time env vars. They do NOT go in .env:
#   - Local dev:  put values in `.dev.vars` (gitignored).
#   - Production: `wrangler secret put <NAME> --config dist/server/wrangler.json`
#                 (or set via the Cloudflare dashboard / GH Actions secrets).
# Names only, listed here for discoverability:
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   GITHUB_CLIENT_ID
#   GITHUB_CLIENT_SECRET
#   BREVO_API_KEY
# The D1 database (binding "DB") is configured in wrangler.toml, not here.
