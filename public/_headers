# Security headers for STATICALLY-served responses (Cloudflare Workers assets).
#
# Why this file exists: under `output: 'static'`, the home page and every
# `/colors/*` page are pre-rendered to `.html` and served by the Cloudflare
# Workers asset layer WITHOUT invoking the worker — so `src/middleware.ts` never
# runs on them and its headers never reach them. This file carries the SAME set
# for those static responses. It does NOT apply to on-demand SSR responses
# (`/[hex]`, `/api/*`, `/og/*`), which are produced by the worker and get their
# headers (plus the CSRF check) from `src/middleware.ts`.
#
# KEEP IN SYNC with the SECURITY_HEADERS / CSP block in src/middleware.ts.
#
# Verify after deploy:
#   curl -sI https://uishades.com/              | grep -i 'content-security\|x-frame\|strict-transport'
#   curl -sI https://uishades.com/colors/coral  | grep -i 'content-security\|x-frame\|strict-transport'

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: clipboard-write=(self), accelerometer=(), camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://www.googletagmanager.com https://www.google-analytics.com https://*.googleusercontent.com https://avatars.githubusercontent.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com; frame-src https://www.googletagmanager.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
