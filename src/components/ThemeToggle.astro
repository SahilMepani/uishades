---
/**
 * ThemeToggle — header light/dark switch.
 *
 * Styling: inherits the header bar's mono/uppercase/tracking so its
 * "Dark" / "Light" label reads the same as it did in the footer. It only
 * needs `text-ink hover:text-accent` to match the surrounding chrome.
 *
 * Behaviour split:
 *   - The pre-paint script in BaseHead sets the initial `.dark` class on
 *     <html> before first paint (no flash).
 *   - Icon + label visibility is driven entirely by CSS keyed on `html.dark`
 *     (see global.css), so the control shows the correct affordance even
 *     before the wiring script below runs.
 *   - This component's script handles the click: flip the class, persist to
 *     localStorage, and keep the aria state in sync. It's a processed (not
 *     inline) script, so Astro bundles + dedupes it — it runs once for the
 *     page regardless of how many footers render it.
 */
---

<button
  type="button"
  data-theme-toggle
  data-theme-bound="0"
  aria-pressed="false"
  aria-label="Switch to dark theme"
  class="inline-flex items-center gap-1.5 text-ink transition-colors duration-150 ease-out hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 motion-reduce:transition-none"
>
  <span data-theme-icon="moon" class="h-3.5 w-3.5 items-center justify-center" aria-hidden="true">
    <svg viewBox="0 0 16 16" class="h-3.5 w-3.5">
      <path
        d="M13.5 9.2A5.2 5.2 0 0 1 6.8 2.5a5.2 5.2 0 1 0 6.7 6.7Z"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linejoin="round"
      />
    </svg>
  </span>
  <span data-theme-icon="sun" class="h-3.5 w-3.5 items-center justify-center" aria-hidden="true">
    <svg viewBox="0 0 16 16" class="h-3.5 w-3.5">
      <circle cx="8" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.4" />
      <path
        d="M8 1v1.6M8 13.4V15M1 8h1.6M13.4 8H15M3 3l1.1 1.1M11.9 11.9 13 13M13 3l-1.1 1.1M4.1 11.9 3 13"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
      />
    </svg>
  </span>
  <span data-theme-label="dark">Dark</span>
  <span data-theme-label="light">Light</span>
</button>

<script>
  const KEY = 'uishades:theme';
  const root = document.documentElement;

  const isDark = () => root.classList.contains('dark');

  function syncButtons() {
    const dark = isDark();
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
      btn.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
    });
  }

  function setTheme(dark: boolean) {
    root.classList.toggle('dark', dark);
    try {
      localStorage.setItem(KEY, dark ? 'dark' : 'light');
    } catch (e) {
      /* storage may be unavailable in private mode */
    }
    syncButtons();
  }

  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    // Per-button guard so a re-run (or a second instance) can't double-bind.
    if (btn.dataset.themeBound === '1') return;
    btn.dataset.themeBound = '1';
    btn.addEventListener('click', () => setTheme(!isDark()));
  });

  syncButtons();
</script>
