---
/**
 * 204-tile random color grid for the homepage.
 *
 * - Deterministic: tiles are sampled from `POPULAR_HEXES` using a fixed-seed
 *   xorshift32 RNG so every build emits the same grid. This keeps the home
 *   page byte-identical across rebuilds and lets the CDN's strong ETag stay
 *   stable, which matters for the cache-hit story.
 * - Layout: CSS grid that switches from 12x17 on desktop down to 6x34 on
 *   mobile via responsive columns. 12 * 17 == 6 * 34 == 204 either way.
 * - Each tile is a static `<a>` to `/[hex]` so Googlebot can crawl the grid
 *   as a link map even though the tool itself is JS.
 */
import { POPULAR_HEXES } from '../lib/data/popular-hexes';

const TILES = 204;

// Tiny xorshift32 PRNG. Fixed seed gives a stable visual identity for the home
// page across builds. The output sequence has period ~2^32, which is way more
// than the 204 draws we need.
function xorshift32(seed: number) {
  let s = seed >>> 0 || 0x9e3779b9;
  return () => {
    s ^= s << 13; s >>>= 0;
    s ^= s >>> 17;
    s ^= s << 5;  s >>>= 0;
    return s / 0x100000000;
  };
}

function pickTiles(): string[] {
  // Per-build rotating seed: stable for a single build (so the rendered
  // HTML / ETag is byte-identical across requests within a deploy) but
  // changes on each rebuild so frequent visitors see a fresh palette.
  // The arithmetic is intentionally tiny — we just want a different
  // 32-bit integer per UTC day; xorshift handles the actual scatter.
  const today = new Date();
  const seed =
    today.getUTCFullYear() * 372 +
    (today.getUTCMonth() + 1) * 31 +
    today.getUTCDate();
  const rng = xorshift32(seed);
  const pool = POPULAR_HEXES;
  const picked = new Set<string>();
  const out: string[] = [];
  // Sample without replacement so the grid doesn't show duplicate tiles.
  let safety = 0;
  while (out.length < TILES && safety < TILES * 8) {
    const idx = Math.floor(rng() * pool.length);
    const hex = pool[idx];
    if (!picked.has(hex)) {
      picked.add(hex);
      out.push(hex);
    }
    safety++;
  }
  return out;
}

const tiles = pickTiles();
---

<section class="random-grid" aria-label="Browse popular colors">
  <div class="grid">
    {tiles.map((hex) => (
      <a
        class="tile"
        href={`/${hex.slice(1)}`}
        style={`--c:${hex}`}
        aria-label={`Open shades for ${hex}`}
      >
        <span class="label">{hex}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .random-grid {
    margin: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    overflow: hidden;
    background: var(--color-paper);
    border: 1px solid var(--color-ink);
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(12, 1fr);
    }
  }
  .tile {
    position: relative;
    background: var(--c);
    aspect-ratio: 1 / 1;
    text-decoration: none;
    color: transparent;
    transition: transform 160ms ease, z-index 0s 160ms;
  }
  .tile:hover, .tile:focus-visible {
    transform: scale(1.18);
    z-index: 2;
    transition: transform 160ms ease, z-index 0s;
    outline: 1px solid var(--color-ink);
  }
  .tile .label {
    position: absolute;
    inset: auto 0 0 0;
    padding: 3px 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-align: center;
    background: var(--color-paper);
    color: var(--color-ink);
    border-top: 1px solid var(--color-ink);
    opacity: 0;
    transition: opacity 120ms ease;
  }
  .tile:hover .label, .tile:focus-visible .label {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile, .tile .label { transition: none; }
    .tile:hover, .tile:focus-visible { transform: none; }
  }
</style>
