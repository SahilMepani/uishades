---
/**
 * Shared <head> chrome: favicon, charset, viewport, generator, and the
 * Google Fonts loading sequence (preconnect -> preload -> stylesheet).
 *
 * Per-page meta — <title>, <meta name="description">, canonical URL,
 * OG/Twitter cards, and the JSON-LD <script> block — stays in each
 * page's own <head> because every page renders them with different
 * content. This component handles only the truly shared bits.
 *
 * Font loading rationale (audit Tier 1.2):
 *   - `@import url(fonts.googleapis.com/...)` lines inside CSS are
 *     render-blocking: the browser can't issue the font HTTP request
 *     until the CSS itself has finished downloading and parsing. That
 *     adds ~100-300 ms to FCP on cold visits.
 *   - Moving to <link rel="preconnect"> + <link rel="preload" as="style">
 *     + <link rel="stylesheet"> lets the browser open the TLS connection
 *     to fonts.gstatic.com in parallel with HTML parsing, fetch the
 *     stylesheet itself with high priority, and discover the font URLs
 *     much earlier.
 *   - All three font URLs are combined into a single Google Fonts CSS
 *     request via the `family=` repetition syntax so we only pay one
 *     round trip instead of three.
 *   - `display=swap` keeps the fallback visible during the swap window
 *     so we never block paint waiting for the webfont.
 */

// A single combined Google Fonts URL: one round trip, three font families.
// Latin subset (the default) covers our copy without per-page `text=`
// hashing. Audit Tier 2.4 tracks a deeper subset for display strings.
const GOOGLE_FONTS_HREF =
  'https://fonts.googleapis.com/css2?' +
  'family=Instrument+Serif:ital@0;1' +
  '&family=Geist:wght@300;400;500;600;700' +
  '&family=JetBrains+Mono:wght@400;500;600' +
  '&display=swap';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />

{/* Font loading: preconnect -> preload -> stylesheet. The stylesheet
    <link> is the actual blocking resource the browser uses; the
    preload primes the cache so it resolves nearly instantly, and the
    preconnects open both TCP+TLS handshakes ahead of the GET. */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style" href={GOOGLE_FONTS_HREF} />
<link rel="stylesheet" href={GOOGLE_FONTS_HREF} media="all" />
