---
/**
 * Shared <head> chrome: favicon, charset, viewport, generator, and the
 * self-hosted font loading sequence.
 *
 * Per-page meta — <title>, <meta name="description">, canonical URL,
 * OG/Twitter cards, and the JSON-LD <script> block — stays in each
 * page's own <head> because every page renders them with different
 * content. This component handles only the truly shared bits.
 *
 * Font loading rationale:
 *   - Fonts are self-hosted via Astro's `fonts` config (see
 *     `astro.config.mjs`). The integration downloads the woff2 files at
 *     build time, ships them from our own origin, and auto-generates a
 *     metric-overridden fallback @font-face so the system-font fallback
 *     occupies the same box as Geist — zero CLS when the swap happens.
 *   - `font-display: 'optional'` keeps first paint instant: if the woff2
 *     hasn't arrived in the ~100 ms block period the browser keeps the
 *     fallback for the whole pageview and warms the cache for next time.
 *     Combined with the size-adjusted fallback this means visitors on
 *     slow connections read a metric-matched system font instead of a
 *     mid-load swap.
 *   - The `<Font preload />` on Geist emits `<link rel="preload">` for
 *     every Geist weight so the LCP element (a `.display`-class heading
 *     in Geist 700) has the best possible chance of painting in Geist on
 *     a cold visit. JetBrains Mono is not preloaded — the mono fallback
 *     is acceptable on first paint and the bytes are better spent on the
 *     sans family that drives perceived render.
 */
import { Font } from 'astro:assets';
---

<!-- Google Tag Manager -->
<script is:inline>
  (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-W6D48RVL');
</script>
<!-- End Google Tag Manager -->

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />

{/* Self-hosted fonts via Astro's fonts API. Geist is preloaded because the
    LCP element on most pages is a `.display`-class heading set in Geist 700;
    JetBrains Mono is loaded without preload (used for secondary hex/mono
    strings whose fallback is acceptable on first paint). */}
<Font cssVariable="--font-geist" preload />
<Font cssVariable="--font-jb-mono" />
