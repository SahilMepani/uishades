---
/**
 * Shared <head> chrome: favicon, charset, viewport, generator, and the
 * self-hosted font loading sequence.
 *
 * Per-page meta - <title>, <meta name="description">, canonical URL,
 * OG/Twitter cards, and the JSON-LD <script> block - stays in each
 * page's own <head> because every page renders them with different
 * content. This component handles only the truly shared bits.
 *
 * Font loading rationale:
 *   - Fonts are self-hosted via Astro's `fonts` config (see
 *     `astro.config.mjs`). The integration downloads the woff2 files at
 *     build time, ships them from our own origin, and auto-generates a
 *     metric-overridden fallback @font-face so the system-font fallback
 *     occupies the same box as Geist - zero CLS when the swap happens.
 *   - `font-display: 'optional'` keeps first paint instant: if the woff2
 *     hasn't arrived in the ~100 ms block period the browser keeps the
 *     fallback for the whole pageview and warms the cache for next time.
 *     Combined with the size-adjusted fallback this means visitors on
 *     slow connections read a metric-matched system font instead of a
 *     mid-load swap.
 *   - The `<Font preload />` on JetBrains Mono emits `<link rel="preload">`
 *     for every mono weight so the hex/mono strings paint in the real
 *     webfont on a cold visit instead of falling back. Geist is not
 *     preloaded - its size-adjusted fallback is acceptable on first paint
 *     and avoids spending cold-load bytes on two preloaded families.
 */
import { Font } from 'astro:assets';
---

{/* Pre-paint theme application. Runs synchronously before first paint so a
    returning visitor's saved dark choice is applied with no flash of the
    light default. Theme is a manual choice persisted to localStorage by the
    header ThemeToggle; the OS preference is intentionally not consulted.
    `is:inline` keeps it un-bundled and blocking - it MUST run before the
    body renders. Default (no stored value) stays light. */}
<script is:inline>
  (function () {
    try {
      if (localStorage.getItem('uishades:theme') === 'dark') {
        document.documentElement.classList.add('dark');
      }
    } catch (e) {}
  })();
</script>

<!-- Google Tag Manager -->
<script is:inline>
  (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-W6D48RVL');
</script>
<!-- End Google Tag Manager -->

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
<link rel="icon" href="/favicon.ico?v=3" />

{/* Self-hosted fonts via Astro's fonts API. JetBrains Mono is preloaded so the
    hex/mono strings paint in the real webfont on a cold visit instead of the
    metric-matched fallback; Geist is loaded without preload (its size-adjusted
    fallback is acceptable on first paint). */}
<Font cssVariable="--font-geist" />
<Font cssVariable="--font-jb-mono" preload />
