---
/**
 * /u/[handle] - the public user profile page.
 *
 * SSR-only (`prerender = false`), INDEXABLE (these are public marketing assets,
 * NOT noindex). Validates the handle regex → loads the user via
 * `getUserByHandle` → 404 if unknown or handle unset. Renders the user's public,
 * non-flagged palettes through the shared `ProfileView` (server-rendered cards
 * for SEO; the island hydrates for voting).
 *
 * PRIVACY: `email` is NEVER read or rendered here. We build a `PublicProfile`
 * by hand from public identity fields only (handle / displayName / avatarUrl),
 * mirroring `/api/u/[handle].json.ts`.
 *
 * Public 30-day edge cache (eventual consistency on palette changes is fine);
 * ProfilePage + CollectionPage JSON-LD injected via the head.
 */
export const prerender = false;

import { env } from 'cloudflare:workers';
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import HeaderAuth from '../../components/HeaderAuth';
import FeedbackLink from '../../components/FeedbackLink';
import ProfileView from '../../components/ProfileView';
import { getUserByHandle, listPublicPalettesByUser } from '../../lib/auth/db';
import { safeJsonForScript } from '../../lib/safe-json';
import type { PublicProfile } from '../../lib/auth/types';

const HANDLE_RE = /^[a-z0-9_-]{3,30}$/;
const handle = (Astro.params.handle ?? '').toLowerCase();
if (!HANDLE_RE.test(handle)) {
  return new Response(null, { status: 404 });
}

const user = await getUserByHandle(env.DB, handle);
// Unknown handle, or a row whose handle was never set → 404 either way.
if (!user || !user.handle) {
  return new Response(null, { status: 404 });
}

// Public, non-flagged palettes only. No viewerId server-side (cacheable body);
// the ProfileView island re-syncs vote state per visitor after hydration.
const palettes = await listPublicPalettesByUser(env.DB, user.id, null);

// Hand-built PublicProfile - email deliberately absent (privacy).
const profile: PublicProfile = {
  handle: user.handle,
  displayName: user.displayName,
  avatarUrl: user.avatarUrl,
  palettes,
};

const displayLabel = profile.displayName ?? profile.handle;
const canonicalUrl = `https://UIshades.com/u/${profile.handle}`;
const ogImage = 'https://UIshades.com/og/4040ff.png';

const TITLE = `${displayLabel} - Color Palettes | UIshades.com`;
const DESCRIPTION = `${displayLabel}'s public color palettes on UIshades.com${
  palettes.length ? ` - ${palettes.length} palette${palettes.length === 1 ? '' : 's'}` : ''
}. Free, ad-free, with Tailwind & OKLCH-ready exports.`;

const profileJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${canonicalUrl}#profile`,
  url: canonicalUrl,
  inLanguage: 'en',
  isPartOf: { '@id': 'https://UIshades.com/#website' },
  mainEntity: {
    '@type': 'Person',
    name: displayLabel,
    alternateName: profile.handle,
    url: canonicalUrl,
    ...(profile.avatarUrl ? { image: profile.avatarUrl } : {}),
  },
  hasPart: {
    '@type': 'CollectionPage',
    name: `${displayLabel}'s palettes`,
    numberOfItems: palettes.length,
    hasPart: palettes.map((p) => ({
      '@type': 'CreativeWork',
      name: p.name,
      url: `https://UIshades.com/p/${p.slug}`,
    })),
  },
};

// Public 30-day edge cache (indexable, no per-user data rendered).
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=2592000, stale-while-revalidate=86400',
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${displayLabel}'s color palettes`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={safeJsonForScript(profileJsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W6D48RVL" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="w-full px-10 lg:px-16">
      <div class="flex items-center justify-between gap-4 border-b border-hairline py-4">
        <a href="/" class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink hover:text-accent">UIshades.com</a>
        <div class="flex items-center gap-4 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/explore" class="text-ink hover:text-accent">Explore</a>
          <a href="/me/palettes" class="text-ink hover:text-accent">My palettes</a>
          <HeaderAuth client:load />
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl px-6 py-12 pb-24 lg:px-8">
      <ProfileView client:load profile={profile} />

      <footer class="mt-20">
        <nav aria-label="Footer" class="flex items-center gap-5 border-t border-hairline pt-6 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/explore" class="text-ink hover:text-accent">Explore</a>
          <a href="/" class="text-ink hover:text-accent">Tool</a>
          <FeedbackLink client:load />
        </nav>
      </footer>
    </main>
  </body>
</html>
