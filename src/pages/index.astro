---
/**
 * Homepage.
 *
 * Renders the shared `ColorToolLayout` shell with a `client:load` ShadeTool
 * seeded with #4040ff - `/` hosts the interactive tool directly. The React
 * island rewrites `/` → `/[hex]` in place on the first user-initiated color
 * change. The site-level Organization / WebSite / SoftwareApplication JSON-LD
 * (referenced by other pages via their `@id`s) lives here and stays on `/`.
 *
 * SSR (not prerendered): the route opts out of prerendering so it can answer
 * `Accept: text/markdown` content negotiation for agents (the asset layer never
 * runs middleware, so a static page couldn't). The HTML branch carries the same
 * 30-day edge cache as `/[hex]`, keyed on `Accept` via `Vary`, so the steady-
 * state cost matches the old static page on a cache hit.
 */
export const prerender = false;

import ColorToolLayout from '../layouts/ColorToolLayout.astro';
import { buildColorPageData } from '../lib/color/page-data';
import { colorPageMarkdown } from '../lib/markdown/color-page';
import { readInitialPrefs } from '../lib/url-prefs';
import { safeJsonForScript } from '../lib/safe-json';

// The hero color `/` is seeded with; the markdown branch renders this color.
const HOME_HEX = '#4040ff';

if ((Astro.request.headers.get('Accept') ?? '').includes('text/markdown')) {
  return new Response(colorPageMarkdown(buildColorPageData(HOME_HEX)), {
    headers: {
      'content-type': 'text/markdown; charset=utf-8',
      'cache-control': 'public, s-maxage=2592000, stale-while-revalidate=86400',
      vary: 'Accept',
    },
  });
}

// Edge-cache the HTML like `/[hex]`; `Vary: Accept` keeps the HTML and markdown
// representations cached independently now that `/` is SSR.
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=2592000, stale-while-revalidate=86400',
);
Astro.response.headers.set('Vary', 'Accept');

const TITLE = 'UI Shades - Free Tints and Shades of Any Hex Color';
const DESCRIPTION =
  'Find tints and shades of any hex color, free. OKLCH ramps, Tailwind 11-stop scales, exports you can paste straight into your code.';
// Single source of truth for the home page's preview image - used for the
// og:image/twitter:image meta AND the SoftwareApplication JSON-LD image, so
// they can't drift apart. #4040ff is the seeded hero color shown on `/`.
const OG = 'https://UIshades.com/og/4040ff.png';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://UIshades.com/#org',
  name: 'UIshades.com',
  url: 'https://UIshades.com/',
  logo: {
    '@type': 'ImageObject',
    url: 'https://UIshades.com/favicon.svg',
    width: 512,
    height: 512,
  },
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://UIshades.com/#website',
  url: 'https://UIshades.com/',
  name: 'UIshades.com',
  description: DESCRIPTION,
  inLanguage: 'en',
  publisher: { '@id': 'https://UIshades.com/#org' },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://UIshades.com/?hex={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': 'https://UIshades.com/#app',
  name: 'UIshades.com',
  url: 'https://UIshades.com/',
  description: DESCRIPTION,
  applicationCategory: 'DesignApplication',
  applicationSubCategory: 'Color Tool',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript. Modern evergreen browser.',
  inLanguage: 'en',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@id': 'https://UIshades.com/#org' },
  image: OG,
  screenshot: OG,
  featureList: [
    '11-stop Tailwind scale generation',
    'OKLCH-anchored color ramps',
    'Exports for Tailwind v4 @theme, Tailwind v3 config, CSS variables, W3C Design Tokens, Figma Variables',
    'WCAG contrast badges on every shade',
    'Permanent shareable URL for every hex',
  ],
};
---

<ColorToolLayout
  title={TITLE}
  description={DESCRIPTION}
  canonical="https://UIshades.com/"
  ogType="website"
  ogImage={OG}
  ogImageAlt="UIshades.com - free tints and shades of any hex color"
  initialHex={HOME_HEX}
  prefs={readInitialPrefs(Astro.url)}
  h1="Tints & shades of any hex color - free OKLCH ramps and Tailwind scales"
  footerHex={HOME_HEX.slice(1)}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={safeJsonForScript(orgJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(websiteJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(appJsonLd)} />
  </Fragment>
</ColorToolLayout>
