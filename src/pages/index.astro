---
/**
 * Homepage.
 *
 * Editorial layout — a magazine masthead instead of a landing page. The
 * type does the work; the random color grid is the only color on the
 * page and it acts as a single typographic-scale woodblock band.
 *
 * Pure HTML/CSS — no React island. The hex input is a plain form whose
 * inline JS canonicalizes the value and client-side navigates.
 */
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import HomeColorPicker from '../components/HomeColorPicker';
import { NAMED_COLORS } from '../lib/data/named-colors';
import { safeJsonForScript } from '../lib/safe-json';

// Bake the CSS-named color list into the inline form script at build time so
// the home page can resolve `coral` / `rebeccapurple` / etc. without booting
// the React island. Filter to `source === 'css'` to keep the payload to ~4 KB
// — the Tailwind/Material/Bootstrap slugs live in the React island where the
// full data set is already loaded for autocomplete.
const HOME_NAMED_COLORS = NAMED_COLORS
  .filter((c) => c.source === 'css')
  .map((c) => ({ slug: c.slug, name: c.name, hex: c.hex }));

const TITLE = 'uishades.com — Free Tints and Shades of Any Hex Color';
const DESCRIPTION =
  'Find tints and shades of any hex color, free. OKLCH ramps, Tailwind 11-stop scales, exports you can paste straight into your code.';
const OG = 'https://uishades.com/og/777777.png';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://uishades.com/#org',
  name: 'uishades.com',
  url: 'https://uishades.com/',
  logo: {
    '@type': 'ImageObject',
    url: 'https://uishades.com/favicon.svg',
    width: 512,
    height: 512,
  },
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://uishades.com/#website',
  url: 'https://uishades.com/',
  name: 'uishades.com',
  description: DESCRIPTION,
  inLanguage: 'en',
  publisher: { '@id': 'https://uishades.com/#org' },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://uishades.com/?hex={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': 'https://uishades.com/#app',
  name: 'uishades.com',
  url: 'https://uishades.com/',
  description: DESCRIPTION,
  applicationCategory: 'DesignApplication',
  applicationSubCategory: 'Color Tool',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript. Modern evergreen browser.',
  inLanguage: 'en',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@id': 'https://uishades.com/#org' },
  image: OG,
  screenshot: OG,
  featureList: [
    'OKLCH-anchored color ramps',
    'Classic RGB-walk shade algorithm',
    '11-stop Tailwind scale generation',
    'Exports for Tailwind v4 @theme, Tailwind v3 config, CSS variables, W3C Design Tokens, Figma Variables',
    'WCAG contrast badges on every shade',
    'Permanent shareable URL for every hex',
  ],
};

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href="https://uishades.com/" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content="https://uishades.com/" />
    <meta property="og:image" content={OG} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="uishades.com — free tints and shades of any hex color" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={OG} />

    <script type="application/ld+json" set:html={safeJsonForScript(orgJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(websiteJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(appJsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W6D48RVL" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <main class="mx-auto max-w-6xl px-6 pb-24">
      <!-- Hero -->
      <section class="mx-auto flex min-h-svh max-w-3xl flex-col items-center justify-center py-10 text-center">
        <p class="eyebrow mb-6">UISHADES.COM — free, fast, OKLCH</p>
        <h1 class="display text-[clamp(2.5rem,8vw,6rem)]">
          Tints &amp; shades<br />
          <span class="text-accent">of any color</span>.
        </h1>
        <p class="mt-8 max-w-[44ch] font-display text-xl leading-snug text-ink-2">
          Paste a hex, <code class="not-italic text-base text-ink">rgb()</code>,
          <code class="not-italic text-base text-ink">hsl()</code>,
          <code class="not-italic text-base text-ink">oklch()</code> or a CSS color name.
        </p>

        <form id="hex-form" class="mt-10 flex w-full max-w-xl flex-col gap-2 text-left" action="/" method="get" novalidate>
          <label for="hex" class="visually-hidden">Color (hex, name, rgb, hsl, or oklch)</label>
          <div class="flex flex-col sm:flex-row border border-ink/80 bg-paper">
            <div class="flex flex-1">
              <HomeColorPicker client:idle />
              <input
                id="hex"
                name="hex"
                type="text"
                placeholder="#4040ff · coral · rgb(64 64 255)"
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
                inputmode="text"
                required
                autofocus
                class="flex-1 bg-transparent px-4 py-3.5 font-mono text-base tracking-tight text-ink placeholder:text-mute focus:outline-none"
              />
            </div>
            <button
              type="submit"
              class="cursor-pointer border-t sm:border-l sm:border-t-0 border-ink/80 bg-ink px-6 py-3.5 font-mono text-[12px] uppercase tracking-[0.18em] text-paper hover:bg-accent focus-visible:bg-accent focus-visible:outline-none"
            >
              Submit
            </button>
          </div>
        </form>
      </section>

      <!-- Editorial "Why" -->
      <section class="mt-20 lg:mt-28" aria-labelledby="why-title">
        <h2 id="why-title" class="sr-only">Why uishades.com</h2>
        <div class="grid gap-x-10 gap-y-12 lg:grid-cols-3">
          <article>
            <p class="idx mb-2">№ 01</p>
            <h3 class="font-display text-2xl text-ink leading-tight">Free, forever.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              No paywall, no signup, no ads. Every hex gets a permanent URL —
              the same one you've had bookmarked for a decade.
            </p>
          </article>
          <article>
            <p class="idx mb-2">№ 02</p>
            <h3 class="font-display text-2xl text-ink leading-tight">Better algorithm.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              OKLCH-anchored ramps keep lightness and hue stable across the
              scale, so yellows, browns, and olives don't muddy out in the
              middle. Want the old behavior? A <em>Classic</em> toggle
              reproduces the RGB-walk output bit for bit.
            </p>
          </article>
          <article>
            <p class="idx mb-2">№ 03</p>
            <h3 class="font-display text-2xl text-ink leading-tight">Tailwind-first exports.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              Drop-in 11-stop scales with copy buttons for Tailwind v4
              <code>@theme</code>, v3 config, plain CSS variables, W3C Design
              Tokens JSON, and Figma Variables.
            </p>
          </article>
        </div>
      </section>

      <!-- Footer / colophon -->
      <footer class="mt-24 border-t border-hairline pt-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-baseline sm:justify-between">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80">
            <a href="/" class="text-ink hover:text-accent">uishades.com</a> · A free design tool
          </p>
          <nav aria-label="Footer" class="flex gap-5 font-mono text-[11px] uppercase tracking-[0.14em]">
            <a href="/colors/coral" class="text-ink hover:text-accent">Named colors</a>
          </nav>
        </div>
        <p class="mt-2 font-display text-sm text-mute">
          Set in Geist and JetBrains Mono. Built with
          <a href="https://astro.build" rel="noopener" class="underline decoration-hairline underline-offset-2 hover:text-accent">Astro</a>.
          Color math by <a href="https://culorijs.org" rel="noopener" class="underline decoration-hairline underline-offset-2 hover:text-accent">culori</a>.
        </p>
      </footer>
    </main>

    <script is:inline define:vars={{ HOME_NAMED_COLORS }}>
      (function () {
        var form = document.getElementById('hex-form');
        if (!form) return;
        var input = document.getElementById('hex');

        // Build a normalized lookup once. Keys are lowercased + whitespace
        // stripped so "Alice Blue" and "aliceblue" both hit.
        var nameToHex = Object.create(null);
        function normName(s) {
          return String(s).toLowerCase().replace(/\s+/g, '');
        }
        for (var i = 0; i < HOME_NAMED_COLORS.length; i++) {
          var c = HOME_NAMED_COLORS[i];
          nameToHex[normName(c.slug)] = c.hex;
          if (c.name) nameToHex[normName(c.name)] = c.hex;
        }

        function hexShape(value) {
          var v = value.trim().toLowerCase();
          if (!v) return null;
          if (v.charAt(0) === '#') v = v.slice(1);
          if (/^[0-9a-f]{6}$/.test(v)) return v;
          if (/^[0-9a-f]{3}$/.test(v)) {
            return v[0] + v[0] + v[1] + v[1] + v[2] + v[2];
          }
          if (/^[0-9a-f]{8}$/.test(v)) return v.slice(0, 6);
          return null;
        }

        function resolveAndGo(raw) {
          if (!raw || !raw.trim()) {
            input.focus();
            return;
          }

          // 1. Hex shape — fast path.
          var slug = hexShape(raw);
          if (slug) {
            window.location.assign('/' + slug);
            return;
          }

          // 2. CSS named color (baked at build).
          var hex = nameToHex[normName(raw)];
          if (hex) {
            // hex is already canonical lowercase `#rrggbb`.
            window.location.assign('/' + hex.slice(1));
            return;
          }

          // 3. Anything else (rgb/hsl/oklch/typo/Tailwind slug/etc.):
          // hand off to the React island via `?seed=`. The island will
          // try to parse it and either swap to the resolved hex (and
          // strip the param) or surface a toast.
          window.location.assign(
            '/4040ff?seed=' + encodeURIComponent(raw.trim()),
          );
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          resolveAndGo(input.value);
        });

        // SearchAction urlTemplate target: /?hex={search_term_string}.
        // Pick up the param at load so external search-engine deep-links
        // land users on the resolved color page instead of an empty form.
        try {
          var seed = new URL(window.location.href).searchParams.get('hex');
          if (seed && seed.trim()) {
            input.value = seed.trim();
            resolveAndGo(seed);
          }
        } catch (_) { /* ignore */ }
      })();
    </script>

    <style>
      .visually-hidden {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </body>
</html>
