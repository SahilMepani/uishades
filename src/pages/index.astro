---
/**
 * Homepage.
 *
 * Editorial layout — a magazine masthead instead of a landing page. The
 * type does the work; the random color grid is the only color on the
 * page and it acts as a single typographic-scale woodblock band.
 *
 * Pure HTML/CSS — no React island. The hex input is a plain form whose
 * inline JS canonicalizes the value and client-side navigates.
 */
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import RandomGrid from '../components/RandomGrid.astro';
import { NAMED_COLORS } from '../lib/data/named-colors';

// Bake the CSS-named color list into the inline form script at build time so
// the home page can resolve `coral` / `rebeccapurple` / etc. without booting
// the React island. Filter to `source === 'css'` to keep the payload to ~4 KB
// — the Tailwind/Material/Bootstrap slugs live in the React island where the
// full data set is already loaded for autocomplete.
const HOME_NAMED_COLORS = NAMED_COLORS
  .filter((c) => c.source === 'css')
  .map((c) => ({ slug: c.slug, name: c.name, hex: c.hex }));

const TITLE = 'shades.dev — Free Tints and Shades of Any Hex Color';
const DESCRIPTION =
  'A free tool for finding lighter and darker shades of any hex color. OKLCH-based ramps, Tailwind-style 11-stop scales, and paste-ready exports.';
const OG = 'https://shades.dev/og/777777.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'shades.dev',
  url: 'https://shades.dev/',
  description: DESCRIPTION,
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const ISSUE_DATE = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href="https://shades.dev/" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content="https://shades.dev/" />
    <meta property="og:image" content={OG} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={OG} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <!-- Masthead strip -->
    <header class="border-b border-ink/90 bg-paper">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80">
        <span>Shades — A free design tool</span>
        <span class="hidden sm:inline">Issue Nº 01 · {ISSUE_DATE}</span>
        <span class="text-accent">Open access</span>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 pb-24 pt-14 lg:pt-20">
      <!-- Hero -->
      <section class="grid gap-10 lg:grid-cols-[7fr_5fr] lg:gap-16">
        <div>
          <p class="eyebrow mb-6">A replacement for 0to255 — free, fast, OKLCH</p>
          <h1 class="display text-[clamp(3rem,9vw,7.5rem)]">
            Tints &amp; shades<br />
            <span class="text-accent">of any color</span>,<br />
            free.
          </h1>
          <p class="mt-8 max-w-[44ch] font-display italic text-xl leading-snug text-ink-2">
            Paste a hex or a CSS color name. <code class="font-mono not-italic text-base text-ink">rgb()</code>,
            <code class="font-mono not-italic text-base text-ink">hsl()</code>, and
            <code class="font-mono not-italic text-base text-ink">oklch()</code> work too — open the tool to use them.
          </p>

          <form id="hex-form" class="mt-10 flex flex-col gap-2 max-w-xl" action="/" method="get" novalidate>
            <label for="hex" class="visually-hidden">Color (hex, name, rgb, hsl, or oklch)</label>
            <div class="flex flex-col sm:flex-row border border-ink/80 bg-paper">
              <input
                id="hex"
                name="hex"
                type="text"
                placeholder="#4040ff · coral · rgb(64 64 255)"
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
                inputmode="text"
                required
                class="flex-1 bg-transparent px-4 py-3.5 font-mono text-base tracking-tight text-ink placeholder:text-mute focus:outline-none"
              />
              <button
                type="submit"
                class="border-t sm:border-l sm:border-t-0 border-ink/80 bg-ink px-6 py-3.5 font-mono text-[12px] uppercase tracking-[0.18em] text-paper hover:bg-accent focus-visible:bg-accent focus-visible:outline-none"
              >
                Open →
              </button>
            </div>
            <p id="hex-error" class="error" role="alert" aria-live="polite"></p>
          </form>
        </div>

        <!-- Right column: editorial "table of contents" -->
        <aside class="hidden lg:flex lg:flex-col lg:items-end lg:pt-4">
          <p class="eyebrow mb-3 self-start">Index</p>
          <ol class="w-full divide-y divide-hairline border-y border-hairline">
            <li class="flex items-baseline justify-between py-3">
              <span class="font-display italic text-xl">The shades tool</span>
              <span class="font-mono text-xs text-mute">№ 01</span>
            </li>
            <li class="flex items-baseline justify-between py-3">
              <span class="font-display italic text-xl">Tailwind scale</span>
              <span class="font-mono text-xs text-mute">№ 02</span>
            </li>
            <li class="flex items-baseline justify-between py-3">
              <span class="font-display italic text-xl">Named colors</span>
              <span class="font-mono text-xs text-mute">№ 03</span>
            </li>
            <li class="flex items-baseline justify-between py-3">
              <span class="font-display italic text-xl">JSON API</span>
              <span class="font-mono text-xs text-mute">№ 04</span>
            </li>
          </ol>
          <p class="mt-6 max-w-[28ch] text-right font-display italic text-base text-mute">
            Same URL pattern as 0to255, OKLCH math underneath, no paywall.
          </p>
        </aside>
      </section>

      <!-- Color grid section -->
      <section class="mt-20 lg:mt-28">
        <div class="mb-4 flex items-baseline justify-between border-b border-ink/80 pb-2">
          <span class="eyebrow">Plate 01 — Sampler</span>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">204 hexes · click to open</span>
        </div>
        <RandomGrid />
      </section>

      <!-- Editorial "Why" -->
      <section class="mt-20 lg:mt-28" aria-labelledby="why-title">
        <div class="mb-10 flex items-baseline justify-between border-b border-ink/80 pb-2">
          <span class="eyebrow">Department</span>
          <h2 id="why-title" class="font-display italic text-3xl text-ink">Why shades.dev</h2>
        </div>
        <div class="grid gap-x-10 gap-y-12 lg:grid-cols-3">
          <article>
            <p class="idx mb-2">№ 01</p>
            <h3 class="font-display italic text-2xl text-ink leading-tight">Free, forever.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              No paywall, no signup, no ads. Permanent URLs for every hex you'd ever
              want to share with a teammate — pattern-identical to the one you've
              had bookmarked for a decade.
            </p>
          </article>
          <article>
            <p class="idx mb-2">№ 02</p>
            <h3 class="font-display italic text-2xl text-ink leading-tight">Better algorithm.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              OKLCH-anchored ramps keep perceived lightness and hue stable across
              the whole scale, so yellows, browns, and olives don't muddy out
              at the mids. A <em class="font-display italic">Classic</em> toggle reproduces the familiar
              RGB-walk output, bit for bit.
            </p>
          </article>
          <article>
            <p class="idx mb-2">№ 03</p>
            <h3 class="font-display italic text-2xl text-ink leading-tight">Tailwind-first exports.</h3>
            <p class="mt-3 text-ink-2 leading-relaxed">
              Drop-in 11-stop scales with copy buttons for Tailwind v4
              <code>@theme</code>, v3 config, plain CSS variables, W3C Design
              Tokens JSON, and Figma Variables.
            </p>
          </article>
        </div>
      </section>

      <!-- Footer / colophon -->
      <footer class="mt-24 border-t border-ink/80 pt-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-baseline sm:justify-between">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80">
            shades.dev · A free design tool
          </p>
          <nav aria-label="Footer" class="flex gap-5 font-mono text-[11px] uppercase tracking-[0.14em]">
            <a href="/colors/coral" class="text-ink hover:text-accent">Named colors</a>
            <a href="https://github.com/sponsors" rel="noopener" class="text-ink hover:text-accent">Sponsor</a>
            <a href="https://ko-fi.com" rel="noopener" class="text-ink hover:text-accent">Ko-fi</a>
          </nav>
        </div>
        <p class="mt-2 font-display italic text-sm text-mute">
          Set in Instrument Serif, Geist, and JetBrains Mono. Built with
          <a href="https://astro.build" rel="noopener" class="underline decoration-hairline underline-offset-2 hover:text-accent">Astro</a>.
          Color math by <a href="https://culorijs.org" rel="noopener" class="underline decoration-hairline underline-offset-2 hover:text-accent">culori</a>.
        </p>
      </footer>
    </main>

    <script is:inline define:vars={{ HOME_NAMED_COLORS }}>
      (function () {
        var form = document.getElementById('hex-form');
        if (!form) return;
        var input = document.getElementById('hex');
        var err = document.getElementById('hex-error');

        // Build a normalized lookup once. Keys are lowercased + whitespace
        // stripped so "Alice Blue" and "aliceblue" both hit.
        var nameToHex = Object.create(null);
        function normName(s) {
          return String(s).toLowerCase().replace(/\s+/g, '');
        }
        for (var i = 0; i < HOME_NAMED_COLORS.length; i++) {
          var c = HOME_NAMED_COLORS[i];
          nameToHex[normName(c.slug)] = c.hex;
          if (c.name) nameToHex[normName(c.name)] = c.hex;
        }

        function hexShape(value) {
          var v = value.trim().toLowerCase();
          if (!v) return null;
          if (v.charAt(0) === '#') v = v.slice(1);
          if (/^[0-9a-f]{6}$/.test(v)) return v;
          if (/^[0-9a-f]{3}$/.test(v)) {
            return v[0] + v[0] + v[1] + v[1] + v[2] + v[2];
          }
          if (/^[0-9a-f]{8}$/.test(v)) return v.slice(0, 6);
          return null;
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var raw = input.value;
          if (!raw || !raw.trim()) {
            err.textContent = 'Enter a hex, color name, rgb(), hsl(), or oklch().';
            input.focus();
            return;
          }

          // 1. Hex shape — fast path.
          var slug = hexShape(raw);
          if (slug) {
            err.textContent = '';
            window.location.assign('/' + slug);
            return;
          }

          // 2. CSS named color (baked at build).
          var hex = nameToHex[normName(raw)];
          if (hex) {
            err.textContent = '';
            // hex is already canonical lowercase `#rrggbb`.
            window.location.assign('/' + hex.slice(1));
            return;
          }

          // 3. Anything else (rgb/hsl/oklch/typo/Tailwind slug/etc.):
          // hand off to the React island via `?seed=`. The island will
          // try to parse it and either swap to the resolved hex (and
          // strip the param) or surface a toast.
          err.textContent = '';
          window.location.assign(
            '/4040ff?seed=' + encodeURIComponent(raw.trim()),
          );
        });
      })();
    </script>

    <style>
      .visually-hidden {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
      }
      .error {
        margin: 0.25rem 0 0;
        color: var(--color-accent);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        min-height: 1.2em;
      }
    </style>
  </body>
</html>
