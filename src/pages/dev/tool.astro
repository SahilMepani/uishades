---
// Development-only host for the React island. Wave 2b will own the public
// `/[hex]` route; until then this page lets us E2E-test the tool in isolation
// and lets the wave-2a agent iterate without conflicting with routing work.
//
// NOTE: we import the global stylesheet through Astro's pipeline rather than
// linking to `/src/...` directly so Tailwind utilities compile cleanly under
// `npm run build` (Playwright's webServer runs `npm run preview`).
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import ShadeTool from '../../components/ShadeTool';
import { readInitialPrefs } from '../../lib/url-prefs';

// Hard-404 in production builds: this is a dev-only host for the React
// island. It's already `noindex` and excluded from the sitemap, but
// returning 404 on the published site removes the page from QA's surface
// entirely. Only `astro dev` (not `astro preview`) keeps the page live.
// The Playwright smoke tests were retargeted at the real /[hex] route
// to compensate; see tests/e2e/tool.spec.ts.
if (import.meta.env.PROD) {
  return new Response(null, { status: 404 });
}

const c = Astro.url.searchParams.get('c') ?? '4040ff';
// Normalize: allow `c=#4040ff` or `c=4040ff`; pass through any other format
// untouched so the React island's parser can have a crack at it.
const cleaned = c.startsWith('#') ? c.slice(1) : c;
const initialHex = `#${cleaned}`;
const prefs = readInitialPrefs(Astro.url);
---

<html lang="en">
  <head>
    <BaseHead />
    <meta name="robots" content="noindex,nofollow" />
    <title>uishades.com — tool (dev)</title>
  </head>
  <body class="m-0 bg-paper text-ink antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W6D48RVL" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <ShadeTool
      client:load
      initialHex={initialHex}
      initialView={prefs.view}
      initialRampMode={prefs.mode}
      initialExportFormat={prefs.fmt}
      initialCopyFormat={prefs.copy}
    />
  </body>
</html>
