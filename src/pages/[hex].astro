---
/**
 * /[hex] — the main shade page. SSR-only (no pre-rendering).
 *
 * Under `output: 'static'`, this route opts out via `prerender = false` so
 * arbitrary hexes are served on demand by the Cloudflare adapter. Each
 * rendered HTML response gets long edge cache; the sitemap pre-warms.
 */
export const prerender = false;

import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import ShadeTool from '../components/ShadeTool';
import { parseColor, ParseError } from '../lib/color/parse';
import { findByHex } from '../lib/data/named-colors';
import { readInitialPrefs } from '../lib/url-prefs';
import { safeJsonForScript } from '../lib/safe-json';
import type { Hex } from '../lib/color/types';

// --- validate the URL param ----------------------------------------------
const rawHex = Astro.params.hex ?? '';
const HEX_RE = /^[0-9a-f]{3}$|^[0-9a-f]{6}$|^[0-9a-f]{8}$/i;
if (!HEX_RE.test(rawHex)) {
  return new Response(null, { status: 404 });
}

let canonical: Hex;
try {
  canonical = parseColor(rawHex);
} catch (e) {
  if (e instanceof ParseError) {
    return new Response(null, { status: 404 });
  }
  throw e;
}

// --- derive everything we need for the page ------------------------------
const named = findByHex(canonical);

const hexLabel = canonical.toUpperCase();
const TITLE = named
  ? `Hex Color ${hexLabel} Tints & Shades · ${named.name} | uishades.com`
  : `Hex Color ${hexLabel} Tints & Shades | uishades.com`;

const DESCRIPTION = named
  ? `${hexLabel} is also known as ${named.name}. Browse tints and shades — free Tailwind-ready exports.`
  : `Tints and shades of hex color ${hexLabel}. Continuous OKLCH ramp, Tailwind-style 11-stop scale, and copy-ready exports.`;

const ogImage = `https://uishades.com/og/${canonical.slice(1)}.png`;
const canonicalUrl = `https://uishades.com/${canonical.slice(1)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: named?.name ?? `Hex color ${hexLabel}`,
  description: DESCRIPTION,
  url: canonicalUrl,
  identifier: hexLabel,
};

const prefs = readInitialPrefs(Astro.url);

// Tell the Cloudflare edge to cache the rendered HTML for 30 days,
// serving stale for an extra day while it revalidates. Same shape as
// the JSON API and OG endpoints — without this header the Workers
// cache won't store the response and every visit re-executes the SSR.
// The hex is already validated above, so all branches that reach here
// are cacheable.
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=2592000, stale-while-revalidate=86400',
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={safeJsonForScript(jsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <main class="mx-auto max-w-6xl px-6 pt-10 pb-24 lg:pt-14">
      <ShadeTool
        client:load
        initialHex={canonical}
        initialView={prefs.view}
        initialRampMode={prefs.mode}
        initialExportFormat={prefs.fmt}
      />

      <noscript>
        <p class="mx-auto max-w-6xl border border-hairline bg-paper-2 px-5 py-4 font-display text-mute">
          Interactive tool requires JavaScript.
        </p>
      </noscript>

      <!-- Footer -->
      <footer class="mt-20 border-t border-ink/80 pt-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-baseline sm:justify-between">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80">
            <a href="/" class="text-ink hover:text-accent">uishades.com</a> · {hexLabel}
          </p>
          <nav aria-label="Footer" class="flex gap-5 font-mono text-[11px] uppercase tracking-[0.14em]">
            <a href="/" class="text-ink hover:text-accent">Home</a>
            <a href="/colors/coral" class="text-ink hover:text-accent">Named colors</a>
          </nav>
        </div>
      </footer>
    </main>
  </body>
</html>
