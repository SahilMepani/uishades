---
/**
 * /[hex] — the main shade page. SSR-only (no pre-rendering).
 *
 * Under `output: 'static'`, this route opts out via `prerender = false` so
 * arbitrary hexes are served on demand by the Cloudflare adapter. Each
 * rendered HTML response gets long edge cache; the sitemap pre-warms.
 */
export const prerender = false;

import { DATE_PUBLISHED, DATE_MODIFIED } from '../lib/site-meta';
import ColorToolLayout from '../layouts/ColorToolLayout.astro';
import { parseColor, ParseError } from '../lib/color/parse';
import { findByHex } from '../lib/data/named-colors';
import { readInitialPrefs } from '../lib/url-prefs';
import { safeJsonForScript } from '../lib/safe-json';
import type { Hex } from '../lib/color/types';

// --- validate the URL param ----------------------------------------------
const rawHex = Astro.params.hex ?? '';
const HEX_RE = /^[0-9a-f]{3}$|^[0-9a-f]{6}$|^[0-9a-f]{8}$/i;
if (!HEX_RE.test(rawHex)) {
  return new Response(null, { status: 404 });
}

let canonical: Hex;
try {
  canonical = parseColor(rawHex);
} catch (e) {
  if (e instanceof ParseError) {
    return new Response(null, { status: 404 });
  }
  throw e;
}

// --- derive everything we need for the page ------------------------------
const named = findByHex(canonical);

const hexLabel = canonical.toUpperCase();
const TITLE = named
  ? `Hex Color ${hexLabel} Tints & Shades · ${named.name} | UIshades.com`
  : `Hex Color ${hexLabel} Tints & Shades | UIshades.com`;

const DESCRIPTION = named
  ? `${hexLabel}, also known as ${named.name}. Browse tints and shades, with Tailwind-ready exports. Free.`
  : `Tints and shades of ${hexLabel}. OKLCH ramp, 11-stop Tailwind scale, copy-ready exports.`;

const ogImage = `https://UIshades.com/og/${canonical.slice(1)}.png`;
const ogImagePin = `https://UIshades.com/og/pin/${canonical.slice(1)}.png`;
const canonicalUrl = `https://UIshades.com/${canonical.slice(1)}`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://UIshades.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: hexLabel,
      item: canonicalUrl,
    },
  ],
};

const hexPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${canonicalUrl}#page`,
  headline: named
    ? `Hex Color ${hexLabel} (${named.name}) — Tints & Shades`
    : `Hex Color ${hexLabel} — Tints & Shades`,
  name: named?.name ?? `Hex color ${hexLabel}`,
  description: DESCRIPTION,
  datePublished: DATE_PUBLISHED,
  dateModified: DATE_MODIFIED,
  url: canonicalUrl,
  identifier: hexLabel,
  inLanguage: 'en',
  isAccessibleForFree: true,
  isPartOf: { '@id': 'https://UIshades.com/#website' },
  publisher: { '@id': 'https://UIshades.com/#org' },
  image: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
    caption: `OG preview card for ${hexLabel}`,
  },
  about: {
    '@type': 'Thing',
    name: named?.name ?? hexLabel,
    identifier: hexLabel,
  },
};

const prefs = readInitialPrefs(Astro.url);

const h1Text = `Tints & shades of ${hexLabel}${named ? ` · ${named.name}` : ''}`;

// Tell the Cloudflare edge to cache the rendered HTML for 30 days,
// serving stale for an extra day while it revalidates. Same shape as
// the JSON API and OG endpoints — without this header the Workers
// cache won't store the response and every visit re-executes the SSR.
// The hex is already validated above, so all branches that reach here
// are cacheable.
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=2592000, stale-while-revalidate=86400',
);
---

<ColorToolLayout
  title={TITLE}
  description={DESCRIPTION}
  canonical={canonicalUrl}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={named ? `Tints and shades of ${hexLabel} (${named.name})` : `Tints and shades of ${hexLabel}`}
  ogImagePin={ogImagePin}
  initialHex={canonical}
  prefs={prefs}
  h1={h1Text}
  footerHex={canonical.slice(1)}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={safeJsonForScript(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(hexPageJsonLd)} />
  </Fragment>
</ColorToolLayout>
