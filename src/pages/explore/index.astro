---
/**
 * /explore - the public palette gallery index.
 *
 * SSR-only (`prerender = false`). Server-renders the DEFAULT sort (`top`) first
 * page via `listPublicPalettes` for SEO/first-paint, then hands that
 * `ExploreResponse` to a `client:load` `ExploreGrid` island that takes over on
 * any filter/sort/pagination interaction (re-querying `/api/explore`).
 *
 * Indexable. Short edge TTL so the gallery stays reasonably fresh while still
 * benefiting from the Cloudflare cache; no per-user data is rendered server-side
 * (the SSR pass passes no `viewerId`, so `votedByMe` is false until the island
 * re-fetches a signed-in view), which keeps this body cacheable.
 */
export const prerender = false;

import { env } from 'cloudflare:workers';
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import HeaderAuth from '../../components/HeaderAuth';
import FeedbackLink from '../../components/FeedbackLink';
import ExploreGrid from '../../components/ExploreGrid';
import { listPublicPalettes } from '../../lib/auth/db';

const canonicalUrl = 'https://UIshades.com/explore';
const TITLE = 'Explore Color Palettes | UI Shades';
const DESCRIPTION =
  'Browse public color palettes from the UIshades community. Sort by top, new, or trending, filter by color and tag, and open any palette with Tailwind & OKLCH-ready exports - free and ad-free.';
const ogImage = 'https://UIshades.com/og/4040ff.png';

// SSR the default-sort first page for SEO. No viewerId here (anonymous,
// cacheable body); the island re-fetches the signed-in view on hydration.
const initialData = await listPublicPalettes(env.DB, { sort: 'top' });

// Short edge TTL - the gallery changes as palettes are created/voted, but a
// minute of staleness at the edge is fine and keeps it fast under load.
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=86400',
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="UIshades color palette gallery" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-paper text-ink">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W6D48RVL" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="w-full px-10 lg:px-16">
      <div class="flex items-center justify-between gap-4 border-b border-hairline py-4">
        <a href="/" class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink hover:text-accent">UI Shades</a>
        <div class="flex items-center gap-4 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/explore" class="text-accent">Explore</a>
          <a href="/me/palettes" class="text-ink hover:text-accent">My palettes</a>
          <HeaderAuth client:load />
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl px-6 py-12 pb-24 lg:px-8">
      <div class="flex flex-col gap-2">
        <span class="kicker">Gallery</span>
        <h1 class="display text-3xl">Explore palettes</h1>
        <p class="mt-1 max-w-2xl font-display text-base text-ink-2">
          Public color palettes from the community. Sort, filter by color or tag,
          and open any one in the tool.
        </p>
      </div>

      <div class="mt-10">
        <ExploreGrid client:load initialData={initialData} initialSort="top" />
      </div>

      <footer class="mt-20">
        <nav aria-label="Footer" class="flex items-center gap-5 border-t border-hairline pt-6 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/colors" class="text-ink hover:text-accent">Named colors</a>
          <a href="/" class="text-ink hover:text-accent">Tool</a>
          <FeedbackLink client:load />
        </nav>
      </footer>
    </main>
  </body>
</html>
