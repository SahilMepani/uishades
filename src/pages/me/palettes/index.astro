---
/**
 * /me/palettes - the signed-in user's private workspace.
 *
 * SSR-only (`prerender = false`): redirects to `/` when logged out, and is
 * `noindex` regardless (private per-user surface, never edge-cached). The page
 * is just a shell hosting the `PalettesDashboard` client island, which fetches
 * `/api/palettes` itself - no per-user data is server-rendered (so nothing can
 * leak into a shared cache).
 */
export const prerender = false;

import '../../../styles/global.css';
import BaseHead from '../../../components/BaseHead.astro';
import ThemeToggle from '../../../components/ThemeToggle.astro';
import HeaderAuth from '../../../components/HeaderAuth';
import FeedbackLink from '../../../components/FeedbackLink';
import PalettesDashboard from '../../../components/PalettesDashboard';
import { currentUserId } from '../../../lib/auth/session';

const userId = await currentUserId(Astro.session);
if (!userId) {
  return Astro.redirect('/');
}

// Private surface - never cached at the edge.
Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>Your palettes | UI Shades</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Your saved palettes on UIshades.com." />
  </head>
  <body class="bg-paper text-ink">
    <header class="w-full px-10 lg:px-16">
      <div class="flex items-center justify-between gap-4 border-b border-hairline py-4">
        <a href="/" class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink hover:text-accent">UI Shades</a>
        <div class="flex items-center gap-4 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/" class="text-ink hover:text-accent">Tool</a>
          <HeaderAuth client:load />
          <ThemeToggle />
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-6xl px-6 py-12 pb-24 lg:px-8">
      <PalettesDashboard client:load />
      <footer class="mt-20">
        <nav aria-label="Footer" class="flex items-center gap-5 border-t border-hairline pt-6 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/colors/coral" class="text-ink hover:text-accent">Named colors</a>
          <a href="/" class="text-ink hover:text-accent">Tool</a>
          <FeedbackLink client:load />
        </nav>
      </footer>
    </main>
  </body>
</html>
