---
/**
 * /colors/[name] — named-color landing pages, pre-rendered.
 *
 * Editorial layout: the blurb is the body copy of a magazine feature; the
 * embedded ShadeTool is the "data sheet"; the complementary/triadic
 * palette is a numbered plate. ~209 pages, one per NAMED_COLORS entry.
 */
import { DATE_PUBLISHED, DATE_MODIFIED } from '../../lib/site-meta';
import { formatForCopy } from '../../lib/color/format';
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import ShadeTool from '../../components/ShadeTool';
import { NAMED_COLORS, findBySlug } from '../../lib/data/named-colors';
import { toOklch, oklchToHex } from '../../lib/color/parse';
import { readInitialPrefs } from '../../lib/url-prefs';
import { safeJsonForScript } from '../../lib/safe-json';
import type { Hex, OKLCH } from '../../lib/color/types';

export async function getStaticPaths() {
  return NAMED_COLORS.map((c) => ({
    params: { name: c.slug },
    props: { slug: c.slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const color = findBySlug(slug);
if (!color) {
  return new Response(null, { status: 404 });
}

function rotate(input: Hex, deg: number): Hex {
  const o: OKLCH = toOklch(input);
  const h = (Number.isFinite(o.h) ? o.h : 0) + deg;
  const hh = ((h % 360) + 360) % 360;
  return oklchToHex({ l: o.l, c: o.c, h: hh });
}

const palette: { label: string; hex: Hex }[] = [
  { label: 'Complementary', hex: rotate(color.hex, 180) },
  { label: 'Triadic',        hex: rotate(color.hex, 120) },
  { label: 'Triadic',        hex: rotate(color.hex, -120) },
  { label: 'Analogous',      hex: rotate(color.hex, 30) },
  { label: 'Analogous',      hex: rotate(color.hex, -30) },
];

const related = (color.related || [])
  .map((s) => findBySlug(s))
  .filter((c): c is NonNullable<typeof c> => !!c)
  .slice(0, 3);

const TITLE = `${color.name} (${color.hex.toUpperCase()}) Color Shades, Tints & Palette | uishades.com`;

function buildDescription(blurb: string): string {
  // Strip inline `code` ticks before any length math so character budgets
  // reflect what Google actually renders in the SERP.
  const clean = blurb.replace(/`([^`]+)`/g, '$1');
  // Prefer to end on a complete sentence. Take as many whole sentences as
  // fit under the 160-char SERP limit; never truncate mid-sentence on a
  // conjunction like "but" or "and", which reads as broken in search
  // results (the original bug on /colors/coral was "...underwater but...").
  const sentences = clean.split(/(?<=\.) /);
  let out = '';
  for (const s of sentences) {
    const next = out ? out + ' ' + s : s;
    if (next.length > 160) break;
    out = next;
  }
  if (out) return out;
  // Edge case: the first sentence alone is already >160 chars. Fall back
  // to word-boundary truncation with an ellipsis — ugly, but only reached
  // by unusually long opening sentences in named-color blurbs.
  const trimmed = clean.slice(0, 157);
  const lastSpace = trimmed.lastIndexOf(' ');
  return (lastSpace > 100 ? trimmed.slice(0, lastSpace) : trimmed) + '...';
}
const DESCRIPTION = buildDescription(color.blurb);

const canonicalUrl = `https://uishades.com/colors/${color.slug}`;
const ogImage = `https://uishades.com/og/${color.hex.slice(1)}.png`;
const ogImagePin = `https://uishades.com/og/pin/${color.hex.slice(1)}.png`;

const plainBlurb = color.blurb.replace(/`([^`]+)`/g, '$1');

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://uishades.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: color.name,
      item: canonicalUrl,
    },
  ],
};

const colorPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${canonicalUrl}#article`,
  headline: `${color.name} (${color.hex.toUpperCase()}) — Tints, Shades & Palette`,
  name: color.name,
  alternateName: color.aliases && color.aliases.length > 0 ? color.aliases : undefined,
  description: plainBlurb,
  datePublished: DATE_PUBLISHED,
  dateModified: DATE_MODIFIED,
  url: canonicalUrl,
  identifier: color.hex.toUpperCase(),
  inLanguage: 'en',
  isAccessibleForFree: true,
  isPartOf: { '@id': 'https://uishades.com/#website' },
  publisher: { '@id': 'https://uishades.com/#org' },
  image: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
    caption: `OG preview card for ${color.name} (${color.hex.toUpperCase()})`,
  },
  keywords: [
    color.name,
    color.hex.toUpperCase(),
    `${color.family} color`,
    'color shades',
    'color tints',
    'tailwind scale',
    'oklch ramp',
  ],
  about: {
    '@type': 'Thing',
    name: color.name,
    identifier: color.hex.toUpperCase(),
    sameAs: color.aliases ?? [],
  },
};

const prefs = readInitialPrefs(Astro.url);

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}
const blurbHtml = escapeHtml(color.blurb).replace(
  /`([^`]+)`/g,
  (_m, inner) => `<code>${inner}</code>`,
);

const oklch = toOklch(color.hex);
const familyLabel = color.family.charAt(0).toUpperCase() + color.family.slice(1);

const faqFirstSentences = plainBlurb.split(/(?<=\.)\s+/).slice(0, 2).join(' ');
const HEXU = color.hex.toUpperCase();
const faq = [
  {
    q: `What is ${color.name}?`,
    a: `${faqFirstSentences} Its hex code is ${HEXU}.`,
  },
  {
    q: `What are the tints and shades of ${color.name}?`,
    a: `uishades builds a 20-step OKLCH ramp for ${color.name} (${HEXU}) — its lightest tints through its darkest shades — plus an 11-stop Tailwind scale (50–950). Lightness steps stay evenly spaced and the hue stays stable, so the mid-tones don't go muddy.`,
  },
  {
    q: `What colors pair well with ${color.name}?`,
    a: `Its complementary color is ${palette[0].hex.toUpperCase()}. Triadic partners are ${palette[1].hex.toUpperCase()} and ${palette[2].hex.toUpperCase()}; analogous neighbours are ${palette[3].hex.toUpperCase()} and ${palette[4].hex.toUpperCase()}.`,
  },
  {
    q: `What are the OKLCH and RGB values of ${color.name}?`,
    a: `${color.name} is ${HEXU} — OKLCH ${oklch.l.toFixed(3)} ${oklch.c.toFixed(3)} ${Number.isFinite(oklch.h) ? oklch.h.toFixed(0) + '°' : '0°'}, ${formatForCopy(color.hex, 'rgb')}, in the ${color.family} family.${color.aliases && color.aliases.length > 0 ? ` Also known as ${color.aliases.join(', ')}.` : ''}`,
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonicalUrl}#faq`,
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${color.name} (${color.hex.toUpperCase()}) — tints, shades, and palette`} />
    {/* Pinterest-optimized 2:3 portrait variant. See note in [hex].astro. */}
    <meta property="og:image" content={ogImagePin} />
    <meta property="og:image:width" content="1000" />
    <meta property="og:image:height" content="1500" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${color.name} (${color.hex.toUpperCase()}) — tints, shades, and palette`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={safeJsonForScript(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(colorPageJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(faqJsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W6D48RVL" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <main class="mx-auto max-w-5xl px-6 pt-10 pb-24 lg:pt-16">
      <!-- Editorial cover -->
      <section class="grid gap-10 lg:grid-cols-[5fr_4fr] lg:gap-14">
        <div>
          <p class="eyebrow mb-3">A study in {familyLabel.toLowerCase()}</p>
          <h1 class="display text-[clamp(3rem,8vw,6.5rem)]">{color.name}</h1>
          <p class="mt-4 font-mono text-base tracking-tight text-ink">{color.hex.toUpperCase()}</p>
          {color.aliases && color.aliases.length > 0 && (
            <p class="mt-2 font-mono text-sm uppercase tracking-[0.14em] text-mute">
              also known as <span class="text-ink-2">{color.aliases.join(', ')}</span>
            </p>
          )}

          <dl class="mt-8 grid grid-cols-4 gap-x-6 border-t border-hairline pt-4 font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
            <div>
              <dt>Family</dt>
              <dd class="mt-1 text-sm normal-case tracking-tight text-ink">{familyLabel}</dd>
            </div>
            <div>
              <dt>L</dt>
              <dd class="mt-1 text-sm normal-case tracking-tight text-ink">{oklch.l.toFixed(3)}</dd>
            </div>
            <div>
              <dt>C</dt>
              <dd class="mt-1 text-sm normal-case tracking-tight text-ink">{oklch.c.toFixed(3)}</dd>
            </div>
            <div>
              <dt>H</dt>
              <dd class="mt-1 text-sm normal-case tracking-tight text-ink">
                {Number.isFinite(oklch.h) ? `${oklch.h.toFixed(0)}°` : '—'}
              </dd>
            </div>
          </dl>
        </div>

        <!-- Hero swatch -->
        <div
          role="img"
          aria-label={`Color ${color.hex}`}
          class="aspect-[4/5] w-full ring-1 ring-ink/15"
          style={`background:${color.hex}`}
        ></div>
      </section>

      <!-- Editorial blurb (drop cap optional via CSS) -->
      <section class="mt-16 border-t border-hairline pt-8">
        <div class="grid gap-8 lg:grid-cols-[1fr_3fr]">
          <p class="eyebrow lg:pt-2">Notes</p>
          <div class="prose-editorial" set:html={`<p>${blurbHtml}</p>`}></div>
        </div>
      </section>

      <!-- Tool -->
      <section class="mt-16 border-t border-hairline pt-8">
        <ShadeTool
          client:load
          initialHex={color.hex}
          initialView={prefs.view}
          initialRampMode={prefs.mode}
          initialExportFormat={prefs.fmt}
          initialCopyFormat={prefs.copy}
        />
      </section>

      <!-- Numbered palette plate -->
      <section class="mt-20 border-t border-hairline pt-8" aria-labelledby="palette-title">
        <div class="mb-6 flex items-baseline justify-between">
          <span class="eyebrow">Plate 02</span>
          <h2 id="palette-title" class="font-display text-2xl text-ink">
            Palette built around {color.name}
          </h2>
        </div>
        <ul class="grid grid-cols-2 gap-0 border-t border-hairline sm:grid-cols-5">
          {palette.map((p, i) => (
            <li class={`border-b border-hairline ${i < palette.length - 1 ? 'sm:border-r' : ''} ${i % 2 === 0 ? 'border-r sm:border-r' : ''}`}>
              <a href={`/${p.hex.slice(1)}`} class="block group">
                <span class="block aspect-square w-full" style={`background:${p.hex}`} aria-hidden="true"></span>
                <span class="flex items-baseline justify-between gap-2 border-t border-hairline px-3 py-2">
                  <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-2">{p.label}</span>
                  <span class="idx">№ 0{i + 1}</span>
                </span>
                <span class="block px-3 pb-3 font-mono text-xs tracking-tight text-ink group-hover:text-accent">
                  {p.hex.toUpperCase()}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Related -->
      {related.length > 0 && (
        <section class="mt-20 border-t border-hairline pt-8" aria-labelledby="related-title">
          <div class="mb-6 flex items-baseline justify-between">
            <span class="eyebrow">Cross-reference</span>
            <h2 id="related-title" class="font-display text-2xl text-ink">Related colors</h2>
          </div>
          <ul class="divide-y divide-hairline border-y border-hairline">
            {related.map((c, i) => (
              <li>
                <a href={`/colors/${c.slug}`} class="flex items-center gap-5 py-4 group hover:bg-paper-2 px-2">
                  <span class="idx">№ 0{i + 1}</span>
                  <span class="block h-6 w-6 ring-1 ring-ink/10 shrink-0" style={`background:${c.hex}`} aria-hidden="true"></span>
                  <span class="font-display text-xl text-ink group-hover:text-accent">{c.name}</span>
                  <span class="ml-auto font-mono text-xs tracking-tight text-mute">{c.hex.toUpperCase()}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- FAQ -->
      <section class="mt-20 border-t border-hairline pt-8" aria-labelledby="faq-title">
        <div class="mb-6 flex items-baseline justify-between">
          <span class="eyebrow">Q&amp;A</span>
          <h2 id="faq-title" class="font-display text-2xl text-ink">Frequently asked questions</h2>
        </div>
        <div class="divide-y divide-hairline border-y border-hairline">
          {faq.map((f) => (
            <div class="py-5">
              <h3 class="font-display text-lg text-ink">{f.q}</h3>
              <p class="mt-2 leading-relaxed text-ink-2">{f.a}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Footer / colophon -->
      <footer class="mt-20 border-t border-hairline pt-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-baseline sm:justify-between">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80">
            <a href="/" class="text-ink hover:text-accent">uishades.com</a> — {color.name}
          </p>
          <nav aria-label="Footer" class="flex gap-5 font-mono text-[11px] uppercase tracking-[0.14em]">
            <a href={`/${color.hex.slice(1)}`} class="text-ink hover:text-accent">Open in tool</a>
            <a href={`/api/${color.hex.slice(1)}.json`} class="text-ink hover:text-accent">View JSON</a>
          </nav>
        </div>
      </footer>
    </main>
  </body>
</html>
