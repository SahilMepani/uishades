---
/**
 * /p/[slug] - the public palette page. The SEO/OG asset for a saved palette.
 *
 * SSR-only (`prerender = false`). Validates the slug, loads the palette via
 * `getPaletteBySlug` (public & non-flagged only for visitors; the owner may
 * preview their own), and 404s otherwise. Server-renders the swatch strip and
 * the Cards mock as a hero (so logged-out visitors see the palette in context),
 * a ShareRow pointed at `/p/[slug]`, an "Open in tool" / "Save a copy" CTA, and
 * CreativeWork + BreadcrumbList JSON-LD via the `head` - all JSON-LD through
 * `safeJsonForScript()`.
 *
 * Public palettes get the same 30-day edge cache as `/[hex]`; owner-previews of
 * a private/flagged palette are NOT cached (per-user). `incrementPaletteView`
 * is fire-and-forget so it never blocks the response.
 */
export const prerender = false;

import { env } from 'cloudflare:workers';
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import HeaderAuth from '../../components/HeaderAuth';
import FeedbackLink from '../../components/FeedbackLink';
import ShareRow from '../../components/ShareRow';
import { getPaletteBySlug, incrementPaletteView } from '../../lib/auth/db';
import { currentUserId } from '../../lib/auth/session';
import { computeMockVars, HERO_MOCK } from '../../components/mocks';
import { safeJsonForScript } from '../../lib/safe-json';
import type { Hex } from '../../lib/color/types';

const SLUG_RE = /^[a-z0-9][a-z0-9-]{0,63}$/;
const slug = Astro.params.slug ?? '';
if (!SLUG_RE.test(slug)) {
  return new Response(null, { status: 404 });
}

const viewerId = await currentUserId(Astro.session);
const palette = await getPaletteBySlug(env.DB, slug, viewerId);
if (!palette) {
  return new Response(null, { status: 404 });
}

const isPublic = palette.visibility === 'public' && !palette.flagged;

// Fire-and-forget view bump - never await it into the response path. Use the
// Cloudflare ExecutionContext's `waitUntil` so the write survives the response.
// In Astro v6 + @astrojs/cloudflare this is `Astro.locals.cfContext`
// (`Astro.locals.runtime.ctx` was REMOVED - reading it THROWS, which 500'd this
// page for every real palette). Guarded so a missing context stays best-effort.
if (isPublic) {
  const bump = incrementPaletteView(env.DB, palette.id).catch(() => {});
  const cfContext = (Astro.locals as { cfContext?: { waitUntil?: (p: Promise<unknown>) => void } })
    .cfContext;
  cfContext?.waitUntil?.(bump);
}

const HeroMock = HERO_MOCK.Component;
const heroVars = computeMockVars(
  palette.colors.map((c) => ({ hex: c.hex, role: c.role })),
);

const canonicalUrl = `https://UIshades.com/p/${palette.slug}`;
const ogImage = `https://UIshades.com/og/p/${palette.slug}.png`;
const ogImagePin = `https://UIshades.com/og/pin/p/${palette.slug}.png`;
const creatorName =
  palette.creator.displayName ?? palette.creator.handle ?? 'Anonymous';

const TITLE = `${palette.name} - Color Palette | UIshades.com`;
const DESCRIPTION = palette.description
  ? palette.description.slice(0, 160)
  : `${palette.name}: a ${palette.colors.length}-color palette with Tailwind & OKLCH-ready exports. Free on UIshades.com.`;

const hexList = palette.colors.map((c) => c.hex);
const firstHex: Hex = hexList[0] ?? '#4040ff';
// "Open in tool" seeds the tool with the first color via the existing ?hex= deep link.
const openInToolUrl = `/?hex=${encodeURIComponent(firstHex)}`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://UIshades.com/' },
    { '@type': 'ListItem', position: 2, name: palette.name, item: canonicalUrl },
  ],
};

const paletteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${canonicalUrl}#palette`,
  name: palette.name,
  headline: `${palette.name} - Color Palette`,
  description: DESCRIPTION,
  datePublished: new Date(palette.createdAt).toISOString(),
  dateModified: new Date(palette.updatedAt).toISOString(),
  url: canonicalUrl,
  inLanguage: 'en',
  isAccessibleForFree: true,
  isPartOf: { '@id': 'https://UIshades.com/#website' },
  publisher: { '@id': 'https://UIshades.com/#org' },
  creator: { '@type': 'Person', name: creatorName },
  keywords: ['color palette', ...palette.tags, ...hexList.map((h) => h.toUpperCase())].join(', '),
  image: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
    caption: `Palette preview for ${palette.name}`,
  },
};

// Public palettes are safe to edge-cache for 30 days; an owner preview of a
// private/flagged palette must stay private (per-user).
Astro.response.headers.set(
  'Cache-Control',
  isPublic
    ? 'public, s-maxage=2592000, stale-while-revalidate=86400'
    : 'private, no-store',
);
if (!isPublic) {
  // Flagged/private palettes reachable only by direct slug must not be indexed.
  Astro.response.headers.set('X-Robots-Tag', 'noindex');
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />
    {!isPublic && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="article" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`Palette preview for ${palette.name}`} />
    <meta property="og:image" content={ogImagePin} />
    <meta property="og:image:width" content="1000" />
    <meta property="og:image:height" content="1500" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`Palette preview for ${palette.name}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={safeJsonForScript(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={safeJsonForScript(paletteJsonLd)} />
  </head>
  <body class="bg-paper text-ink">
    <header class="w-full px-10 lg:px-16">
      <div class="flex items-center justify-between gap-4 border-b border-hairline py-4">
        <a href="/" class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink hover:text-accent">UIshades.com</a>
        <div class="flex items-center gap-4 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/me/palettes" class="text-ink hover:text-accent">My palettes</a>
          <HeaderAuth client:load />
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl px-6 py-12 pb-24 lg:px-8">
      <div class="flex flex-col gap-2">
        <span class="kicker">Palette</span>
        <h1 class="display text-3xl">{palette.name}</h1>
        <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-mute">
          {palette.colors.length} colors · by {creatorName}
        </p>
        {palette.description && (
          <p class="mt-2 max-w-2xl font-display text-base text-ink-2">{palette.description}</p>
        )}
      </div>

      {/* Swatch strip - inline-style fills (theme-toggle-safe). */}
      <ul class="mt-8 flex flex-wrap gap-3">
        {palette.colors.map((c) => (
          <li class="flex flex-col gap-1.5">
            <span
              class="block h-20 w-20 rounded-sm ring-1 ring-ink/15 sm:h-24 sm:w-24"
              style={`background-color:${c.hex}`}
            />
            <span class="font-mono text-[11px] tracking-tight text-ink-2">{c.hex.toUpperCase()}</span>
            {c.role && (
              <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-mute">{c.role}</span>
            )}
          </li>
        ))}
      </ul>

      {/* Cards mock hero - the palette applied to a real surface (SSR, no client JS). */}
      <section class="mt-12">
        <span class="eyebrow">In context</span>
        <div class="mt-3 overflow-hidden rounded-md border border-hairline" style={{ aspectRatio: '16 / 9' }}>
          <div style={heroVars} class="h-full w-full">
            <HeroMock />
          </div>
        </div>
      </section>

      {/* CTAs + share */}
      <section class="mt-12 flex flex-col gap-6 border-t border-hairline pt-8">
        <div class="flex flex-wrap items-center gap-3">
          <a
            href={openInToolUrl}
            class="inline-flex items-center gap-1.5 bg-ink px-4 py-2.5 font-mono text-sm uppercase tracking-tight text-paper transition-opacity duration-150 ease-out hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60"
          >
            Open in tool →
          </a>
          <a
            href={openInToolUrl}
            class="inline-flex items-center gap-1.5 border border-ink/20 bg-paper-2 px-4 py-2.5 font-mono text-sm uppercase tracking-tight text-ink transition-colors duration-150 ease-out hover:bg-paper-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60"
          >
            Save a copy
          </a>
        </div>
        <ShareRow
          client:load
          hex={firstHex}
          shareUrl={canonicalUrl}
          title={`${palette.name} - a color palette on UIshades.com`}
          pinMedia={ogImagePin}
        />
      </section>

      <footer class="mt-20">
        <nav aria-label="Footer" class="flex items-center gap-5 border-t border-hairline pt-6 font-mono text-[11px] uppercase tracking-[0.14em]">
          <a href="/colors/coral" class="text-ink hover:text-accent">Named colors</a>
          <a href="/" class="text-ink hover:text-accent">Tool</a>
          <FeedbackLink client:load />
        </nav>
      </footer>
    </main>
  </body>
</html>
