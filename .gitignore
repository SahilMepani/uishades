# build output
dist/

# generated types
.astro/

# dependencies
node_modules/

# cloudflare / wrangler
.wrangler/
# Local Worker secrets (OAuth client id/secret, Brevo key). Names documented in
# .env.example; values never committed.
.dev.vars
# Generated by `npm run cf-typegen` (reflects local wrangler.toml + .env); each
# dev regenerates it. Auth secrets are declared in src/worker-env.d.ts.
worker-configuration.d.ts

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables (allow .env.example)
.env
.env.*
!.env.example

# tests
playwright-report/
test-results/
.lighthouseci/
# Local Lighthouse JSON runs collected by `npm run build && npx lighthouse ...`
.lh-out/

# macOS-specific files
.DS_Store

# MSYS/Cygwin crash dumps
*.stackdump

# jetbrains setting folder
.idea/

# Data generator intermediates — see .tmp-gen/generate.mjs. Authored sources
# (.tmp-gen/blurbs.json, .tmp-gen/generate.mjs) ARE committed; intermediate
# JSON artifacts and ad-hoc dumps are not.
.tmp-gen/named-colors.partial.json
.tmp-gen/popular-hexes.json
.tmp-gen/slugs.txt
